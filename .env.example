# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/saas_form_filler

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=changeme_use_at_least_256_bits_of_entropy
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
