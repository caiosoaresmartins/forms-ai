# === Database ===
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/saas_form_filler

# === Redis ===
REDIS_URL=redis://redis:6379/0

# === JWT ===
JWT_SECRET=troque-por-um-segredo-forte-aqui
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# === Groq API ===
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# === Supabase Storage ===
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_BUCKET=forms

# === Criptografia em repouso (Fernet) ===
ENCRYPTION_KEY=

# === Métricas Prometheus ===
METRICS_TOKEN=

# === LGPD ===
DATA_RETENTION_DAYS=90
AUDIT_LOG_RETENTION_YEARS=7

# === Rate Limits ===
RATE_LIMIT_AUTH_PER_MINUTE=10
RATE_LIMIT_UPLOAD_PER_HOUR=50

# === Frontend (Next.js) ===
NEXT_PUBLIC_API_URL=http://localhost:8000
